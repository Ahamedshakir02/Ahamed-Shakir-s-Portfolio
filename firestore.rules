rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // The user email from runtime is ahamedshakir02@gmail.com
      return isSignedIn() && (request.auth.token.email == 'ahamedshakir02@gmail.com' && request.auth.token.email_verified == true);
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Experience ---
    match /experience/{expId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Projects ---
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Posts ---
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
